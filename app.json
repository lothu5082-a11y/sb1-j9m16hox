{
  "expo": {
    "name": "Vexora AI",
    "slug": "vexora-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "vexora",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "android": {
      "package": "com.vexoraai.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0A0E1A"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vexoraai.app"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow Vexora to use the microphone for voice commands",
          "speechRecognitionPermission": "Allow Vexora to recognise your speech"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "baseUrl": "/sb1-j9m16hox"
    }
  }
}
